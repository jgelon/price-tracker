# PriceWatch — environment configuration
# Copy this file to .env and adjust values before running docker compose up

# ── Public URL ────────────────────────────────────────────────────────────────
# The hostname Traefik will route to the frontend (no https://, no trailing slash)
APP_HOST=pricewatch.example.com

# ── Port (direct access, used when Traefik is NOT in front) ──────────────────
FRONTEND_PORT=18080

# ── Backend ───────────────────────────────────────────────────────────────────
# Set to DEBUG for verbose scraper output, INFO for normal production use
LOG_LEVEL=INFO

# ── Traefik ───────────────────────────────────────────────────────────────────
# Name of the existing external Docker network Traefik listens on
TRAEFIK_NETWORK=traefik_proxy

# Name of the Traefik entrypoint for HTTPS (commonly "websecure" or "https")
TRAEFIK_ENTRYPOINT=websecure

# Traefik cert-resolver name (leave empty to disable automatic TLS)
TRAEFIK_CERTRESOLVER=letsencrypt
